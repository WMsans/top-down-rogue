#include "res://shaders/generated/materials.glslinc"

struct Context {
    ivec2 chunk_coord;
    uint world_seed;
};

void stage_stone_fill(Context ctx) {
    ivec2 pos = ivec2(gl_GlobalInvocationID.xy);
    if (pos.x >= 256 || pos.y >= 256) return;

    // Stone: material=2, health=255, temperature=0, reserved=0
    vec4 pixel = vec4(float(MAT_STONE) / 255.0, 1.0, 0.0, 0.0);
    imageStore(chunk_tex, pos, pixel);
}